local function fetchWikipedia(query)
    local url = "https://en.wikipedia.org/w/api.php?action=query&prop=extracts&format=json&explaintext=&titles="..HttpService:UrlEncode(query)
    local success, response = pcall(function() return HttpService:RequestAsync({Url=url, Method="GET"}) end)
    if not success then return nil,nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(response.Body) end)
    if not ok then return nil,nil end
    for _, v in pairs(data.query.pages) do
        if v.missing then return nil,nil end
        return v.title or "无标题", v.extract or "无内容"
    end
    return nil,nil
end

local function fetchRandomWikipedia()
    local url="https://en.wikipedia.org/w/api.php?action=query&list=random&rnnamespace=0&rnlimit=1&format=json"
    local success,response = pcall(function() return HttpService:RequestAsync({Url=url, Method="GET"}) end)
    if not success then return nil,nil end
    local ok,data = pcall(function() return HttpService:JSONDecode(response.Body) end)
    if not ok then return nil,nil end
    local title=data.query.random[1].title
    return fetchWikipedia(title)
