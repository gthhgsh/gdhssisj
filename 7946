local _localPlayer = game.Players.LocalPlayer

function PlayerProtection.AntiVoid:_createPlatform()
    if self._platform then
        self._platform:Destroy()
    end
    
    self._platform = Instance.new("Part")
    self._platform.Name = "AntiVoidPlatform"
    self._platform.Size = Vector3.new(50, 2, 50)
    self._platform.Anchored = true
    self._platform.CanCollide = true
    self._platform.Material = Enum.Material.Plastic
    self._platform.Transparency = 0.9
    self._platform.BrickColor = BrickColor.new("Institutional white")
    self._platform.Parent = workspace
end

function PlayerProtection.AntiVoid:_core()
    local character = _localPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if rootPart and humanoid and humanoid.Health > 0 then
        if rootPart.Position.Y < self._voidY then
            -- 在玩家下方创建透明平台
            if not self._platform then
                self:_createPlatform()
            end
            -- 将平台放置在玩家下方稍低的位置
            local platformPosition = Vector3.new(
                rootPart.Position.X,
                self._voidY - 5,  -- 在虚空界限下方5个单位创建平台
                rootPart.Position.Z
            )
            self._platform.Position = platformPosition
        else
            -- 玩家在安全高度，移除平台
            if self._platform then
                self._platform:Destroy()
                self._platform = nil
            end
        end
    else
        -- 角色无效，移除平台
        if self._platform then
            self._platform:Destroy()
            self._platform = nil
        end
    end
end

function PlayerProtection.AntiVoid:enable()
    self._enabled = true
    if self._loop then self._loop:Disconnect() end
    self._loop = self._services.RunService.RenderStepped:Connect(function()
        self:_core()
    end)
    self._services.CoreGui:SetCore("SendNotification", {
        Title = "防虚空平台已开启",
        Text = "Y轴<" .. self._voidY .. "时生成透明平台",
        Duration = 3
    })
end

function PlayerProtection.AntiVoid:disable()
    self._enabled = false
    if self._loop then
        self._loop:Disconnect()
        self._loop = nil
    end
    if self._platform then
        self._platform:Destroy()
        self._platform = nil
    end
    self._services.CoreGui:SetCore("SendNotification", {
        Title = "防虚空平台已关闭",
        Text = "不再生成透明平台",
        Duration = 3
    })
end

function PlayerProtection.Respawn:_setupRespawnTracking()
    if self._deathConnection then
        self._deathConnection:Disconnect()
        self._deathConnection = nil
    end
    
    self._deathConnection = _localPlayer.CharacterAdded:Connect(function(character)
        local humanoid = character:WaitForChild("Humanoid")
        
        humanoid.Died:Connect(function()
            if self._enabled and character:FindFirstChild("HumanoidRootPart") then
                self._lastPosition = character.HumanoidRootPart.Position
            end
        end)
    end)
    
    if _localPlayer.Character then
        local humanoid = _localPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Died:Connect(function()
                if self._enabled and _localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    self._lastPosition = _localPlayer.Character.HumanoidRootPart.Position
                end
            end)
        end
    end
end

function PlayerProtection.Respawn:_teleportToDeathPosition()
    if not self._lastPosition then
        _G.NotifyWarning("提示", "没有找到死亡位置记录", 3)
        return
    end
    
    local character = _localPlayer.Character
    
    if not character then
        _G.NotifyError("错误", "角色不存在", 3)
        return
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        _G.NotifyError("错误", "找不到HumanoidRootPart", 3)
        return
    end
    
    humanoidRootPart.CFrame = CFrame.new(self._lastPosition)
    _G.NotifySuccess("成功", "已传送到上次死亡位置", 3)
end

function PlayerProtection.Respawn:_setupAutoRespawn()
    _localPlayer.CharacterAdded:Connect(function(character)
        if self._enabled and self._lastPosition then
            local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
            if humanoidRootPart then
                humanoidRootPart.CFrame = CFrame.new(self._lastPosition)
                _G.Notify("原地复活", "已自动传送到死亡位置", 3)
            end
        end
    end)
end

function PlayerProtection.Respawn:enable()
    self._enabled = true
    _G.Notify("原地复活", "原地复活功能已开启", 3)
end

function PlayerProtection.Respawn:disable()
    self._enabled = false
    _G.Notify("原地复活", "原地复活功能已关闭", 3)
end

function PlayerProtection.Respawn:teleportToDeath()
    self:_teleportToDeathPosition()
end

